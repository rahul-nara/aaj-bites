---
interface Props {
  rating: number;
}

const { rating = 0 } = Astro.props as Props;

// Convert 10 → 5 scale
const ratingOutOfTen = Math.round(rating);
const ratingOutOfFive = ratingOutOfTen / 2;

const fullStars = Math.floor(ratingOutOfFive);
const halfStar = ratingOutOfFive - fullStars >= 0.5 ? 1 : 0;
const emptyStars = 5 - fullStars - halfStar;
const starRatingId = `star-${Math.random().toString(36).slice(2, 9)}`;
---

