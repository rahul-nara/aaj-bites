---
import Logo from "@components/global/Logo.astro";
import type { SiteConfig } from '@app-types/config';

type FooterProps = {
    siteConfig: SiteConfig;
}
const { siteConfig } = Astro.props as FooterProps;
console.log(siteConfig);
---

<footer class="bg-[var(--primary-color)]">
    <div class="py-[30px]">
        <div class="container">
            <div class="flex items-center justify-between gap-[100px]">
                <Logo logo={siteConfig.footer.logo} href="/" priority={false} />
                <div class="w-full max-w-full">
                    <div class="w-full max-w-full text-white text-base font-medium prose prose-h3:text-white prose-h3:mb-[15px] prose-p:text-white prose-p:text-base prose-p:font-medium prose-p:leading-normal mb-[15px]" set:html={siteConfig.footer.footerContent}></div>
                    <div class="flex items-center gap-4">
                        <a href={`tel:${siteConfig.footer.phone}`} class="text-white text-base font-medium inline-flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 21 21" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M20.3881 15.4201V18.4201C20.3892 18.6986 20.3322 18.9743 20.2206 19.2294C20.1091 19.4846 19.9454 19.7137 19.7402 19.902C19.535 20.0902 19.2927 20.2336 19.0289 20.3228C18.765 20.412 18.4855 20.4452 18.2081 20.4201C15.131 20.0857 12.1751 19.0342 9.57812 17.3501C7.16194 15.8148 5.11345 13.7663 3.57812 11.3501C1.88809 8.7413 0.83636 5.77109 0.508117 2.6801C0.483127 2.40356 0.515992 2.12486 0.604617 1.86172C0.693243 1.59859 0.835688 1.35679 1.02288 1.15172C1.21008 0.94665 1.43792 0.782806 1.69191 0.670619C1.94589 0.558432 2.22046 0.500358 2.49812 0.500097H5.49812C5.98342 0.495321 6.45391 0.667176 6.82188 0.98363C7.18985 1.30008 7.43019 1.73954 7.49812 2.2201C7.62474 3.18016 7.85957 4.12282 8.19812 5.0301C8.33266 5.38802 8.36178 5.77701 8.28202 6.15098C8.20227 6.52494 8.01698 6.86821 7.74812 7.1401L6.47812 8.4101C7.90167 10.9136 9.97457 12.9865 12.4781 14.4101L13.7481 13.1401C14.02 12.8712 14.3633 12.6859 14.7372 12.6062C15.1112 12.5264 15.5002 12.5556 15.8581 12.6901C16.7654 13.0286 17.7081 13.2635 18.6681 13.3901C19.1539 13.4586 19.5975 13.7033 19.9146 14.0776C20.2318 14.4519 20.4003 14.9297 20.3881 15.4201Z" stroke="#fff" stroke-linecap="round" stroke-linejoin="round"/></svg> <span>{siteConfig.footer.phone}</span></a>
                        <a href={`mailto:${siteConfig.footer.email}`} class="text-white text-base font-medium inline-flex items-center gap-2"><svg width="18" height="15" viewBox="0 0 21 17" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M18.5001 0.5H2.50006C1.39549 0.5 0.500061 1.39543 0.500061 2.5V14.5C0.500061 15.6046 1.39549 16.5 2.50006 16.5H18.5001C19.6046 16.5 20.5001 15.6046 20.5001 14.5V2.5C20.5001 1.39543 19.6046 0.5 18.5001 0.5Z" stroke="#fff" stroke-linecap="round" stroke-linejoin="round"/><path d="M20.5001 3.5L11.5301 9.2C11.2213 9.39343 10.8644 9.49601 10.5001 9.49601C10.1357 9.49601 9.77879 9.39343 9.47006 9.2L0.500061 3.5" stroke="#fff" stroke-linecap="round" stroke-linejoin="round"/></svg> <span>{siteConfig.footer.email}</span></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="py-[15px] border-t border-[var(--quinary-color)] text-center">
        <div class="container">
            <div class="flex items-center justify-between gap-4">
                <p class="text-white text-base font-medium">{siteConfig.footer.copyright}</p>
                <nav class="flex items-center gap-4">
                    {siteConfig.footer.navigation.map((link) => (
                        <a href={link.url} class="text-white text-base font-medium" title={link.label}>{link.label}</a>
                    ))}
                </nav>
            </div>
        </div>
    </div>
</footer>
